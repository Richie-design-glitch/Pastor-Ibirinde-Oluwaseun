<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pastor Ibirinde Oluwaseun | RCCG</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600&display=swap');
        
        body {
            font-family: 'Inter', system-ui, sans-serif;
        }
        
        .heading-font {
            font-family: 'Playfair Display', serif;
        }

        .hero-bg {
            background: linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), url('https://picsum.photos/id/1015/2000/1200') center/cover no-repeat;
        }

        .nav-link {
            transition: all 0.3s ease;
        }
        
        .nav-link:hover {
            color: #facc15;
            transform: translateY(-2px);
        }

        .sermon-card {
            transition: all 0.4s ease;
        }
        
        .sermon-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
        }

        .gold-accent {
            color: #facc15;
        }
    </style>
</head>
<body class="bg-zinc-50 text-zinc-800">
    <!-- NAVBAR -->
    <nav class="bg-white shadow-md fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-yellow-400 rounded-full flex items-center justify-center text-2xl">✝️</div>
                <div>
                    <h1 class="heading-font text-2xl font-bold text-zinc-900">Pastor Ibirinde</h1>
                    <p class="text-xs tracking-widest text-amber-600 -mt-1">RCCG</p>
                </div>
            </div>

            <!-- Desktop Menu -->
            <div class="hidden md:flex items-center gap-8 text-sm font-medium">
                <a href="#home" class="nav-link text-zinc-700 hover:text-amber-500">Home</a>
                <a href="#about" class="nav-link text-zinc-700 hover:text-amber-500">About</a>
                <a href="#sermons" class="nav-link text-zinc-700 hover:text-amber-500">Sermons</a>
                <a href="#contact" class="nav-link text-zinc-700 hover:text-amber-500">Contact</a>
            </div>

            <!-- Mobile Hamburger -->
            <button id="mobile-menu-btn" class="md:hidden text-2xl text-zinc-800">
                <i class="fa-solid fa-bars"></i>
            </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t px-6 py-6">
            <div class="flex flex-col gap-5 text-center text-lg font-medium">
                <a href="#home" class="nav-link">Home</a>
                <a href="#about" class="nav-link">About</a>
                <a href="#sermons" class="nav-link">Sermons</a>
                <a href="#contact" class="nav-link">Contact</a>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section id="home" class="hero-bg h-screen flex items-center text-white">
        <div class="max-w-5xl mx-auto px-6 text-center">
            <div class="max-w-2xl mx-auto">
                <p class="text-amber-300 tracking-[4px] text-sm mb-3">REDEEMED CHRISTIAN CHURCH OF GOD</p>
                <h1 class="heading-font text-6xl md:text-7xl font-bold leading-tight mb-6">
                    Pastor Ibirinde<br>Oluwaseun
                </h1>
                <p class="text-xl md:text-2xl mb-10 text-amber-100">
                    "For I am not ashamed of the gospel of Christ: for it is the power of God unto salvation"
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="#sermons" 
                       class="bg-amber-400 hover:bg-amber-500 text-zinc-900 font-semibold px-10 py-4 rounded-full transition-all text-lg inline-flex items-center gap-2 justify-center">
                        <i class="fa-solid fa-play"></i>
                        Listen to Sermons
                    </a>
                    <a href="#contact" 
                       class="border-2 border-white hover:bg-white hover:text-zinc-900 font-semibold px-10 py-4 rounded-full transition-all text-lg">
                        Get in Touch
                    </a>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 flex flex-col items-center">
            <p class="text-xs tracking-widest mb-2 text-amber-200">SCROLL TO EXPLORE</p>
            <i class="fa-solid fa-chevron-down animate-bounce text-2xl"></i>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="py-24 bg-white">
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
            <!-- Photo -->
            <div class="relative">
                <div class="absolute -inset-6 bg-gradient-to-br from-amber-400 to-yellow-300 rounded-3xl -rotate-6"></div>
                <img id="pastor-photo" 
                     src="https://picsum.photos/id/1011/800/900" 
                     alt="Pastor Ibirinde Oluwaseun"
                     class="relative rounded-3xl shadow-2xl w-full object-cover h-full min-h-[500px]">
                <div class="absolute -bottom-5 -right-5 bg-white p-5 rounded-2xl shadow-xl">
                    <div class="flex items-center gap-3">
                        <div class="text-4xl">🇳🇬</div>
                        <div>
                            <p class="font-semibold">Lagos, Nigeria</p>
                            <p class="text-xs text-zinc-500">RCCG Province / Parish</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bio -->
            <div>
                <span class="px-4 py-2 bg-amber-100 text-amber-700 text-xs font-semibold rounded-full">SENIOR PASTOR</span>
                <h2 class="heading-font text-5xl font-bold mt-6 mb-8 leading-tight">
                    A Man Called by God to Shepherd His People
                </h2>
                
                <div class="prose text-zinc-600 text-lg leading-relaxed">
                    <p class="mb-6">
                        Hello, I am <strong>Pastor Ibirinde Oluwaseun</strong>, a servant of the Most High God and a Pastor in the Redeemed Christian Church of God (RCCG).
                    </p>
                    <p class="mb-6">
                        <strong>Replace this paragraph with your personal testimony or calling story.</strong> 
                        Example: "I was called into ministry in 2015 after a powerful encounter with the Holy Spirit. Since then, I have been privileged to lead souls to Christ, plant churches, and teach the undiluted Word of God."
                    </p>
                    <p>
                        My passion is to see lives transformed through the power of the Gospel. I believe every believer is called to greatness.
                    </p>
                </div>

                <div class="mt-12 grid grid-cols-3 gap-6 text-center">
                    <div>
                        <p class="text-4xl font-bold text-amber-500">15+</p>
                        <p class="text-sm text-zinc-500">Years in Ministry</p>
                    </div>
                    <div>
                        <p class="text-4xl font-bold text-amber-500">500+</p>
                        <p class="text-sm text-zinc-500">Souls Won</p>
                    </div>
                    <div>
                        <p class="text-4xl font-bold text-amber-500">8</p>
                        <p class="text-sm text-zinc-500">Sermons Monthly</p>
                    </div>
                </div>

                <a href="#contact" 
                   class="mt-10 inline-block bg-zinc-900 text-white px-8 py-4 rounded-full hover:bg-amber-500 hover:text-zinc-900 transition-all font-medium">
                    Book a Meeting or Prayer Session →
                </a>
            </div>
        </div>
    </section>

    <!-- SERMONS SECTION -->
    <section id="sermons" class="py-24 bg-zinc-100">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-amber-600 text-sm font-semibold tracking-widest">PREACHING THE WORD</span>
                <h2 class="heading-font text-5xl font-bold mt-3">Latest Sermons</h2>
                <p class="mt-4 text-zinc-600 max-w-md mx-auto">
                    "Faith comes by hearing, and hearing by the word of God" – Romans 10:17
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Sermon 1 -->
                <div class="sermon-card bg-white rounded-3xl overflow-hidden shadow-lg">
                    <div class="h-48 bg-zinc-200 flex items-center justify-center">
                        <i class="fa-solid fa-microphone text-6xl text-amber-400"></i>
                    </div>
                    <div class="p-8">
                        <div class="flex justify-between text-xs mb-4">
                            <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Sunday Service</span>
                            <span class="text-zinc-500">March 9, 2025</span>
                        </div>
                        <h3 class="font-semibold text-xl mb-3">The Power of Persistent Prayer</h3>
                        <p class="text-zinc-600 text-sm line-clamp-3">
                            A powerful teaching on Luke 18:1-8 – why we must never give up in the place of prayer.
                        </p>
                        <div class="mt-8 flex items-center gap-3 text-xs">
                            <span class="flex-1 h-px bg-zinc-200"></span>
                            <a href="#" class="gold-accent font-medium flex items-center gap-1">
                                LISTEN NOW <i class="fa-solid fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Sermon 2 -->
                <div class="sermon-card bg-white rounded-3xl overflow-hidden shadow-lg">
                    <div class="h-48 bg-zinc-200 flex items-center justify-center">
                        <i class="fa-solid fa-microphone text-6xl text-amber-400"></i>
                    </div>
                    <div class="p-8">
                        <div class="flex justify-between text-xs mb-4">
                            <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Midweek Service</span>
                            <span class="text-zinc-500">March 5, 2025</span>
                        </div>
                        <h3 class="font-semibold text-xl mb-3">Walking in Divine Favour</h3>
                        <p class="text-zinc-600 text-sm line-clamp-3">
                            Understanding how to activate uncommon favour from God in every area of your life.
                        </p>
                        <div class="mt-8 flex items-center gap-3 text-xs">
                            <span class="flex-1 h-px bg-zinc-200"></span>
                            <a href="#" class="gold-accent font-medium flex items-center gap-1">
                                WATCH NOW <i class="fa-solid fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Sermon 3 -->
                <div class="sermon-card bg-white rounded-3xl overflow-hidden shadow-lg">
                    <div class="h-48 bg-zinc-200 flex items-center justify-center">
                        <i class="fa-solid fa-microphone text-6xl text-amber-400"></i>
                    </div>
                    <div class="p-8">
                        <div class="flex justify-between text-xs mb-4">
                            <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Special Service</span>
                            <span class="text-zinc-500">March 2, 2025</span>
                        </div>
                        <h3 class="font-semibold text-xl mb-3">The Holy Spirit: Our Helper</h3>
                        <p class="text-zinc-600 text-sm line-clamp-3">
                            A fresh revelation on the person and work of the Holy Spirit in the life of the believer.
                        </p>
                        <div class="mt-8 flex items-center gap-3 text-xs">
                            <span class="flex-1 h-px bg-zinc-200"></span>
                            <a href="#" class="gold-accent font-medium flex items-center gap-1">
                                DOWNLOAD <i class="fa-solid fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-12">
                <p class="text-sm text-zinc-500 mb-4">More sermons available on YouTube &amp; SoundCloud</p>
                <a href="#" 
                   class="inline-flex items-center gap-3 border border-zinc-300 hover:border-amber-400 px-8 py-3 rounded-2xl text-sm font-medium transition-colors">
                    <i class="fa-brands fa-youtube text-red-500"></i>
                    VIEW ALL SERMONS ON Y
